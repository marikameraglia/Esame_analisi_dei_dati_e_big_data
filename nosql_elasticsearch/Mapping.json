# 1. Creazione indice hotel con mappatura geografica
PUT /hotel
{
  "mappings": {
    "properties": {
      "id_hotel": { "type": "keyword" },
      "nome": { "type": "text" },
      "descrizione": { "type": "text" },
      "citta": { "type": "keyword" },
      "prezzo_notte": { "type": "float" },
      "servizi": { "type": "keyword" },
      "posizione": { "type": "geo_point" }
    }
  }
}

# 2. Creazione indice recensioni
PUT /recensioni
{
  "mappings": {
    "properties": {
      "id_recensione": { "type": "keyword" },
      "id_hotel": { "type": "keyword" },
      "utente": { "type": "keyword" },
      "testo_recensione": { "type": "text" },
      "punteggio_pulizia": { "type": "integer" },
      "punteggio_servizi": { "type": "integer" },
      "data_recensione": { "type": "date" }
    }
  }
}
